# -----------------------------------------------------------------------------
# Supabase (London / eu-west-2 project). Omit these to use in-memory mock data
# and persona auth (local dev / CI without a database).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Site URL for auth email redirects and PKCE callback (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=

# Set to "mock" to force mock data even when Supabase env vars are present.
# DATA_PROVIDER=mock
